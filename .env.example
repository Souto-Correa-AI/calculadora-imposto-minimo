# =============================================================
# Calculadora IRPFM — variáveis de ambiente
# Copie este arquivo para .env e preencha com as credenciais reais.
# NÃO commite .env. (já está no .gitignore)
# Em produção (Railway), defina estas vars no dashboard do serviço.
# =============================================================

# Chave da API Mailchimp (Account → Profile → Extras → API keys).
# Formato: "abcdef0123456789-us21"
MC_API_KEY=

# Data center da conta Mailchimp.
# Costuma ser o sufixo da API key (depois do "-"). Exemplos: us21, us19, us6.
MC_DC=

# ID da Audience (lista) que vai receber os leads.
# Audience → Settings → Audience name and defaults → Audience ID.
MC_LIST_ID=

# Porta HTTP local. Em produção o Railway injeta PORT automaticamente.
PORT=3000
